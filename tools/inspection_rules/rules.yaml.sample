# Rule 5: Fail inspection for unsupported hardware
- uuid: rule-reject-old-cpu
  description: "Reject nodes with insufficient CPU cores"
  priority: 50
  phase: main
  conditions:
    - op: lt
      args:
        - "{inventory[cpu][count]}"
        - 4
  actions:
    - op: fail
      args:
        msg: "Node has insufficient CPU cores (minimum 4 required)"

# Rule 6: Set boot mode based on firmware
- uuid: rule-boot-mode-uefi
  description: "Set UEFI boot mode for modern systems"
  priority: 60
  phase: main
  conditions:
    - op: eq
      args:
        - "{inventory[boot][current_boot_mode]}"
        - "uefi"
  actions:
    - op: set-capability
      args:
        name: "boot_mode"
        value: "uefi"
    - op: log
      args:
        msg: "Configured UEFI boot mode"
        level: info
