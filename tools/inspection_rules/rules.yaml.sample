# Sample Inspection Rules
# This file demonstrates various inspection rule patterns

# Rule 1: Set BMC credentials for Dell servers
- uuid: rule-dell-bmc-setup
  description: "Configure iDRAC for Dell servers"
  priority: 100
  sensitive: true
  phase: main
  conditions:
    - op: contains
      args:
        value: "{inventory[system_vendor][manufacturer]}"
        regex: "(?i)dell"
    - op: is-true
      args:
        value: "{node.auto_discovered}"
  actions:
    - op: set-attribute
      args:
        path: "/driver"
        value: "idrac"
    - op: set-attribute
      args:
        path: "/driver_info/redfish_address"
        value: "https://{inventory[bmc_address]}"
    - op: log
      args:
        msg: "Configured iDRAC driver for Dell server"
        level: info

# Rule 2: Add traits based on hardware capabilities
- uuid: rule-add-hardware-traits
  description: "Add traits for high-memory nodes"
  priority: 90
  phase: main
  conditions:
    - op: "!lt"
      args:
        - [{inventory.memory.physical_mb}, 65536]
  actions:
    - op: add-trait
      args:
        name: "CUSTOM_HIGH_MEMORY"
    - op: set-capability
      args:
        name: "memory_class"
        value: "high"

